# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/swa-change-requests

# Server
PORT=5001

# Optional: Google Gemini for live AI drafts (omit to use mock drafts)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Force mock AI even when GEMINI_API_KEY is set (avoids quota errors)
# USE_MOCK_AI=true
