# MongoDB (use MongoDB Atlas connection string on Render)
MONGODB_URI=mongodb://127.0.0.1:27017/swa-change-requests

# Render sets PORT automatically
PORT=5001
NODE_ENV=development

# Seed dummy Jira tickets when DB is empty (set true on first Render deploy)
SEED_ON_START=true

# Optional: Google Gemini for live AI drafts
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
USE_MOCK_AI=false

# Optional: comma-separated origins if frontend is hosted separately
# CLIENT_URL=https://your-static-site.onrender.com

# Optional: for future Jira Automation webhook
# JIRA_WEBHOOK_SECRET=
